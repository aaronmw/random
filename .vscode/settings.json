{
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "deno.enablePaths": ["supabase/functions"],
  "deno.lint": true,
  "deno.unstable": true,
  "tailwindCSS.rootFontSize": 11,
  "workbench.colorTheme": "Cursor Dark Midnight",
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#a165eb",
    "activityBar.background": "#a165eb",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#f0ba8e",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#a165eb",
    "statusBar.background": "#8638e5",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#a165eb",
    "statusBarItem.remoteBackground": "#8638e5",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#8638e5",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#8638e599",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#8638E5"
}
