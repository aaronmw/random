{
  "name": "figma-property-randomizer",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "PORT=4000 concurrently -n plugin,next 'npm run build:plugin -- --watch --define:SITE_URL=\\\"http://localhost:4000\\\"' 'next dev --turbopack'",
    "start": "next start",
    "build": "concurrently -n plugin,next 'npm run build:plugin -- --define:SITE_URL=\\\"$npm_package_config_siteURL\\\"' 'next build'",
    "lint": "next lint",
    "build:plugin": "esbuild plugin/code.ts --bundle --target=es6 --loader:.svg=text --outfile=plugin/dist/code.js",
    "build:next": "next build",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "supabase:build-types": "supabase gen types typescript --project-id cirrjwaknafiuaxaczrf > supabase/generated-types.ts"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-alpha.8",
    "@figma/plugin-typings": "*",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "colord": "^2.9.3",
    "esbuild": "^0.25.4",
    "eslint": "^9.27.0",
    "eslint-config-next": "15.3.2",
    "immer": "^10.1.1",
    "jotai": "^2.12.4",
    "lodash": "^4.17.21",
    "natural-compare-lite": "^1.4.0",
    "next": "^15.3.2",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^6.0.0",
    "tailwind-merge": "^3.3.0",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.1.7",
    "tiny-invariant": "^1.3.3",
    "typescript": "^5.8.3",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.16",
    "@types/natural-compare-lite": "^1.4.2",
    "babel-plugin-react-compiler": "^19.1.0-rc.2",
    "concurrently": "^9.1.2",
    "cypress": "^14.3.3",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier-plugin-tailwindcss": "^0.6.11"
  },
  "config": {
    "siteURL": "https://rewrite--figma-property-randomizer.netlify.app/"
  },
  "overrides": {
    "usehooks-ts": {
      "react": "^19.1.0",
      "react-dom": "^19.1.0"
    }
  }
}
