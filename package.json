{
  "name": "figma-property-randomizer",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "PORT=4000 concurrently -n plugin,next 'npm run build:plugin -- --watch --define:SITE_URL=\\\"http://localhost:4000\\\"' 'next dev --turbopack'",
    "start": "next start",
    "build": "concurrently -n plugin,next 'npm run build:plugin -- --define:SITE_URL=\\\"$npm_package_config_siteURL\\\"' 'next build'",
    "lint": "next lint",
    "build:plugin": "esbuild plugin/code.ts --bundle --target=es6 --loader:.svg=text --outfile=plugin/dist/code.js",
    "build:next": "next build",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write ."
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-alpha.6",
    "@figma/plugin-typings": "*",
    "@tailwindcss/postcss": "^4.0.4",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "colord": "^2.9.3",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.1.6",
    "jotai": "^2.12.1",
    "lodash": "^4.17.21",
    "natural-compare-lite": "^1.4.0",
    "next": "^15.1.6",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^5.0.0",
    "tailwind-merge": "^3.0.1",
    "tailwind-scrollbar": "^4.0.0",
    "tailwindcss": "^4.0.4",
    "tiny-invariant": "^1.3.3",
    "typescript": "^5.7.3",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.15",
    "@types/natural-compare-lite": "^1.4.2",
    "babel-plugin-react-compiler": "^19.0.0-beta-e1e972c-20250221",
    "concurrently": "^9.1.2",
    "cypress": "^14.0.2",
    "eslint-plugin-react-compiler": "^19.0.0-beta-e1e972c-20250221",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier-plugin-tailwindcss": "^0.6.11"
  },
  "config": {
    "siteURL": "https://rewrite--figma-property-randomizer.netlify.app/"
  },
  "overrides": {
    "usehooks-ts": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    }
  }
}
